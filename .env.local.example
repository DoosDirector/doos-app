# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only – used for admin/service-role actions (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Maps ─────────────────────────────────────────────────
# Create an API key at: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Directions API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# App ─────────────────────────────────────────────────────────
# Used for absolute URLs in OG tags and shareable links
NEXT_PUBLIC_APP_URL=http://localhost:3000
