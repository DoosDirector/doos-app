# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored and must NEVER be committed.
#
# Production (Vercel): set these under
#   Project Settings → Environment Variables → Production
# ─────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
# Both are REQUIRED in production.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only – used for admin/service-role operations that bypass RLS
# (never expose to the browser; prefix must NOT be NEXT_PUBLIC_)
# REQUIRED in production.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Maps ─────────────────────────────────────────────────
# Create an API key at: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Directions API
# Restrict the key to your production domain to prevent abuse.
# REQUIRED in production (map stops feature will not work without it).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# App ─────────────────────────────────────────────────────────
# Absolute base URL used for OG image tags and sitemap.
# Must NOT have a trailing slash.
# Defaults to https://doos.app in production if unset, but set it explicitly.
# REQUIRED in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E2E tests (local / CI only – do NOT set in Vercel production) ───────────────
# Used by Playwright smoke tests (npm run test:e2e).
# E2E_EMAIL=test@example.com
# E2E_PASSWORD=supersecret
# PLAYWRIGHT_BASE_URL=http://localhost:3000
